---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="About · Sotavento Labs"
  description="Sotavento is the leeward side of a sail. We help engineering teams navigate complexity — diagnosing before prescribing, building what needs to be built, and stepping away."
>
  <!-- Skip to content for keyboard/screen-reader users -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- NAVIGATION -->
  <nav id="navbar" aria-label="Main navigation">
    <a href="/" class="logo" aria-label="Sotavento Labs — home">
      <img src="/logo.png" alt="Sotavento Labs logo" class="logo-img" />
      Sotavento Labs
    </a>
    <a href="/" class="back-link">← Back</a>
  </nav>

  <main id="main-content">
    <!-- HERO -->
    <section class="hero">
      <div class="section-wrap">
        <span class="eyebrow">ABOUT</span>
        <h1>Complexity is the wind.<br />We are the shelter.</h1>
        <p class="body-text">
          Sotavento is the leeward side of a sail, the side where the wind stops pushing
          and starts pulling you forward. That is how we work: not against the
          forces shaping your organisation, but with them.
        </p>
      </div>
    </section>

    <!-- HOW WE WORK -->
    <section class="how-section">
      <div class="section-wrap">
        <span class="eyebrow">HOW WE WORK</span>
        <h2>We show up, build what needs to be built, and step away.</h2>
        <p class="body-text">
          We help engineering teams understand the full landscape of forces
          around them. Then we design systems that help them navigate change,
          while respecting existing team dynamics and organisational structures.
        </p>
        <p class="body-text">
          No rigid frameworks. No long-term dependency. We diagnose before we
          prescribe, work within real constraints, and leave once the momentum
          is yours.
        </p>
      </div>
    </section>

    <!-- PILLARS -->
    <section class="pillars-section">
      <div class="section-wrap">
        <span class="eyebrow">WHAT DRIVES US</span>
        <h2 class="pillars-heading">Three ways we create leverage.</h2>
      </div>
      <div class="pillars">
        <article class="pillar">
          <h3>We read the wind.</h3>
          <p class="pillar-body">
            Deep diagnosis before action. We map the technical, organisational,
            and market forces at play before recommending anything. Most firms
            prescribe. We observe first.
          </p>
        </article>
        <article class="pillar">
          <h3>We reposition the vessel.</h3>
          <p class="pillar-body">
            Rather than brute-force transformation: strategic pivots, process
            realignment, structural redesign. Transformation is not force.
            It is placement.
          </p>
        </article>
        <article class="pillar">
          <h3>We create leverage.</h3>
          <p class="pillar-body">
            Once positioned correctly, effort multiplies. Competitive insulation,
            sustainable delivery, energy efficiency. Built to last after we
            have left.
          </p>
        </article>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="contact-section">
      <div class="section-wrap">
        <span class="eyebrow">GET IN TOUCH</span>
        <h2>Let's talk.</h2>
        <p class="body-text">
          If you want a partner who reads the situation before acting on it,
          reach out.
        </p>
        <a href="mailto:hello@sotaventolabs.eu" class="contact-link">
          hello@sotaventolabs.eu →
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script is:inline>
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.registerPlugin(ScrollTrigger);

      document.querySelectorAll('.hero, .how-section, .pillars-section, .contact-section, .pillar').forEach((el) => {
        gsap.from(el, {
          opacity: 0,
          y: 30,
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        });
      });
    }
  </script>
</Layout>

<style>
  :root {
    --white: #ffffff;
    --zinc-100: #f4f4f5;
    --zinc-400: #a1a1aa;
    --zinc-500: #71717a;
    --zinc-600: #52525b;
    --zinc-800: #27272a;
    --ink: #1d1d1f;
    --nav-h: 72px;
    --content-max-w: 680px;
  }

  /* ─── SKIP LINK ─── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 200;
    padding: 0.5rem 1rem;
    background: var(--ink);
    color: #fff;
    font-size: 0.875rem;
    border-radius: 0 0 6px 6px;
    transition: top 0.15s;
  }
  .skip-link:focus { top: 0; }

  /* ─── NAV ─── */
  #navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 3rem;
    height: var(--nav-h);
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    color: var(--ink);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.975rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: inherit;
    text-decoration: none;
  }
  .logo:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 3px;
    border-radius: 3px;
  }

  .logo-img {
    height: 32px;
    width: auto;
    display: block;
  }

  .back-link {
    font-size: 0.875rem;
    color: inherit;
    opacity: 0.65;
    transition: opacity 0.2s;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .back-link:hover { opacity: 1; }
  .back-link:focus-visible {
    opacity: 1;
    outline: 2px solid var(--ink);
    outline-offset: 3px;
    border-radius: 3px;
  }

  /* ─── HERO ─── */
  .hero {
    background: var(--white);
    padding: calc(var(--nav-h) + 8rem) 3rem 8rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--ink);
  }

  /* ─── EYEBROW ─── */
  .eyebrow {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--zinc-500);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  /* ─── BODY TEXT ─── */
  .body-text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--zinc-600);
  }

  /* ─── SECTION WRAP ─── */
  .section-wrap {
    max-width: var(--content-max-w);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ─── HOW WE WORK ─── */
  .how-section {
    background: var(--zinc-100);
    padding: 8rem 3rem;
  }

  .how-section h2 {
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  /* ─── PILLARS ─── */
  .pillars-section {
    background: var(--white);
    padding: 8rem 3rem;
  }

  .pillars-heading {
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .pillars {
    margin-top: 3rem;
    max-width: var(--content-max-w);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .pillar {
    border-top: 1px solid #e4e4e7;
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pillar h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .pillar-body {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--zinc-600);
  }

  /* ─── CONTACT ─── */
  .contact-section {
    background: var(--zinc-100);
    padding: 8rem 3rem;
  }

  .contact-section h2 {
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .contact-link {
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    align-self: flex-start;
    transition: opacity 0.2s;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .contact-link:hover { opacity: 0.6; }
  .contact-link:focus-visible {
    opacity: 1;
    outline: 2px solid var(--ink);
    outline-offset: 3px;
    border-radius: 3px;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 640px) {
    #navbar { padding: 0 1.5rem; }
    .hero { padding: calc(var(--nav-h) + 5rem) 1.5rem 5rem; }
    .how-section, .pillars-section, .contact-section { padding: 5rem 1.5rem; }
  }
</style>
