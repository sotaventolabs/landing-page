---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="About · Sotavento Labs"
  description="Sotavento is the leeward side of a sail. We help engineering teams navigate complexity — diagnosing before prescribing, building what needs to be built, and stepping away."
>
  <!-- Skip to content for keyboard/screen-reader users -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- NAVIGATION -->
  <nav id="navbar" aria-label="Main navigation">
    <a href="/" class="logo" aria-label="Sotavento Labs — home">
      <img src="/logo.svg" alt="Sotavento Labs logo" class="logo-img" />
      Sotavento Labs
    </a>
    <a href="/" class="back-link">← Back</a>
  </nav>

  <main id="main-content">
    <!-- HERO -->
    <section class="hero">
      <div class="section-wrap">
        <span class="eyebrow">ABOUT</span>
        <h1>Complexity is the wind.<br />We are the shelter.</h1>
        <p class="body-text">
          Sotavento is the leeward side of a sail, the side where the wind stops pushing
          and starts pulling you forward. That is how we work: not against the
          forces shaping your organisation, but with them.
        </p>
      </div>
    </section>

    <!-- HOW WE WORK -->
    <section class="how-section">
      <div class="section-wrap">
        <span class="eyebrow">HOW WE WORK</span>
        <h2>We show up, build what needs to be built, and step away.</h2>
        <p class="body-text">
          We help engineering teams understand the full landscape of forces
          around them. Then we design systems that help them navigate change,
          while respecting existing team dynamics and organisational structures.
        </p>
        <p class="body-text">
          No rigid frameworks. No long-term dependency. We diagnose before we
          prescribe, work within real constraints, and leave once the momentum
          is yours.
        </p>
      </div>
    </section>

    <!-- PILLARS -->
    <section class="pillars-section">
      <div class="section-wrap">
        <span class="eyebrow">WHAT DRIVES US</span>
        <h2 class="pillars-heading">Three ways we create leverage.</h2>
      </div>
      <div class="pillars">
        <article class="pillar">
          <h3>We read the wind.</h3>
          <p class="pillar-body">
            Deep diagnosis before action. We map the technical, organisational,
            and market forces at play before recommending anything. Most firms
            prescribe. We observe first.
          </p>
        </article>
        <article class="pillar">
          <h3>We reposition the vessel.</h3>
          <p class="pillar-body">
            Rather than brute-force transformation: strategic pivots, process
            realignment, structural redesign. Transformation is not force.
            It is placement.
          </p>
        </article>
        <article class="pillar">
          <h3>We create leverage.</h3>
          <p class="pillar-body">
            Once positioned correctly, effort multiplies. Competitive insulation,
            sustainable delivery, energy efficiency. Built to last after we
            have left.
          </p>
        </article>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="contact-section">
      <div class="section-wrap">
        <span class="eyebrow">GET IN TOUCH</span>
        <h2>Let's talk.</h2>
        <p class="body-text">
          If you want a partner who reads the situation before acting on it,
          reach out.
        </p>
        <a href="mailto:hello@sotaventolabs.eu" class="contact-link">
          hello@sotaventolabs.eu →
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script is:inline>
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.registerPlugin(ScrollTrigger);

      document.querySelectorAll('.hero, .how-section, .pillars-section, .contact-section, .pillar').forEach((el) => {
        gsap.from(el, {
          opacity: 0,
          y: 30,
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        });
      });
    }
  </script>
</Layout>

<style>
  /* ─── SKIP LINK ─── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-4);
    z-index: 200;
    padding: var(--space-2) var(--space-4);
    background: var(--ink);
    color: var(--fg-inverse);
    font-size: var(--fs-caption);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    transition: top var(--dur-fast);
  }
  .skip-link:focus { top: 0; }

  /* ─── NAV ─── */
  #navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--page-pad-x);
    height: var(--nav-h);
    background: var(--glass-bg-light);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: var(--hairline-light);
    color: var(--fg-1);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.975rem;
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-snug);
    color: inherit;
    text-decoration: none;
  }

  .logo-img {
    height: 32px;
    width: auto;
    display: block;
  }

  .back-link {
    font-size: var(--fs-caption);
    color: inherit;
    opacity: 0.65;
    transition: opacity 0.2s;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .back-link:hover { opacity: 1; }

  /* ─── HERO ─── */
  .hero {
    background: var(--surface);
    padding: calc(var(--nav-h) + var(--space-10)) var(--page-pad-x) var(--space-10);
  }

  .hero h1 {
    font-size: clamp(var(--fs-h1-min), 3.5vw, var(--fs-h1-max));
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--lh-display);
    color: var(--fg-1);
  }

  /* ─── EYEBROW ─── */
  .eyebrow {
    display: inline-block;
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-eyebrow);
    color: var(--fg-3);
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  /* ─── BODY TEXT ─── */
  .body-text {
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--fg-2);
  }

  /* ─── SECTION WRAP ─── */
  .section-wrap {
    max-width: var(--content-max-w);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ─── HOW WE WORK ─── */
  .how-section {
    background: var(--surface-2);
    padding: var(--space-10) var(--page-pad-x);
  }

  .how-section h2 {
    font-size: clamp(var(--fs-h2-min), 2.5vw, var(--fs-h2-max));
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
    color: var(--fg-1);
  }

  /* ─── PILLARS ─── */
  .pillars-section {
    background: var(--surface);
    padding: var(--space-10) var(--page-pad-x);
  }

  .pillars-heading {
    font-size: clamp(var(--fs-h2-min), 2.5vw, var(--fs-h2-max));
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
    color: var(--fg-1);
  }

  .pillars {
    margin-top: 3rem;
    max-width: var(--content-max-w);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .pillar {
    border-top: 1px solid var(--border-1);
    padding-top: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pillar h3 {
    font-size: var(--fs-card-title);
    font-weight: var(--fw-semibold);
    color: var(--fg-1);
    letter-spacing: var(--tracking-tightish);
  }

  .pillar-body {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--fg-2);
  }

  /* ─── CONTACT ─── */
  .contact-section {
    background: var(--surface-2);
    padding: var(--space-10) var(--page-pad-x);
  }

  .contact-section h2 {
    font-size: clamp(var(--fs-h2-min), 2.5vw, var(--fs-h2-max));
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
    color: var(--fg-1);
  }

  .contact-link {
    font-size: var(--fs-body);
    font-weight: var(--fw-medium);
    color: var(--fg-1);
    align-self: flex-start;
    transition: opacity 0.2s;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .contact-link:hover { opacity: 0.6; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 640px) {
    #navbar { padding: 0 var(--page-pad-x-sm); }
    .hero { padding: calc(var(--nav-h) + 5rem) var(--page-pad-x-sm) 5rem; }
    .how-section, .pillars-section, .contact-section { padding: 5rem var(--page-pad-x-sm); }
  }
</style>
