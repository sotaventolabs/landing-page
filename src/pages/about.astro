---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About — Sotavento Labs">
  <!-- NAVIGATION -->
  <nav id="navbar">
    <a href="/" class="logo">
      <img src="/logo.png" alt="" class="logo-img" />
      Sotavento Labs
    </a>
    <a href="/" class="back-link">← Back</a>
  </nav>

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="section-wrap">
        <span class="eyebrow">ABOUT US</span>
        <h1>Technology consulting<br />for teams that build.</h1>
        <p class="body-text">
          Sotavento Labs is a technology consulting studio. We partner with
          engineering teams to design, build, and ship software — from early
          architecture decisions to hands-on delivery.
        </p>
      </div>
    </section>

    <!-- WHAT WE DO -->
    <section class="what-section">
      <div class="section-wrap">
        <span class="eyebrow">WHAT WE DO</span>
        <h2>We work alongside your team, not above it.</h2>
        <p class="body-text">
          We embed with teams to solve hard engineering problems — infrastructure,
          system design, delivery process, or whatever is actually blocking
          progress. We care about the craft and the outcome in equal measure.
        </p>
        <p class="body-text">
          Alongside our consulting practice we build our own tools, shaped by
          problems we keep running into in the field.
        </p>
      </div>
    </section>

    <!-- TEAM -->
    <section class="team-section">
      <div class="team-header">
        <span class="eyebrow">THE TEAM</span>
        <h2>People</h2>
      </div>
      <div class="person-grid">
        <article class="person-card">
          <div class="person-info">
            <span class="person-name">Gonzalo Rubio-Casas</span>
            <span class="person-role">Founder &amp; Engineer</span>
          </div>
          <p class="person-bio">
            Software engineer focused on distributed systems, cloud
            infrastructure, and developer tooling. Has worked across product
            companies and consulting engagements throughout Europe.
          </p>
          <a
            href="https://linkedin.com/company/sotavento-labs/"
            target="_blank"
            rel="noopener noreferrer"
            class="person-link"
          >
            LinkedIn →
          </a>
        </article>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="contact-section">
      <div class="section-wrap">
        <span class="eyebrow">GET IN TOUCH</span>
        <h2>Let's talk.</h2>
        <p class="body-text">
          Whether you're looking for a consulting partner or just want to compare
          notes, reach out.
        </p>
        <a href="mailto:hello@sotaventolabs.eu" class="contact-link">
          hello@sotaventolabs.eu →
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script is:inline>
    gsap.registerPlugin(ScrollTrigger);

    document.querySelectorAll('.hero, .what-section, .team-section, .contact-section, .person-card').forEach((el) => {
      gsap.from(el, {
        opacity: 0,
        y: 30,
        duration: 0.8,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          toggleActions: 'play none none none',
        },
      });
    });
  </script>
</Layout>

<style>
  :root {
    --white: #ffffff;
    --zinc-100: #f4f4f5;
    --zinc-400: #a1a1aa;
    --zinc-500: #71717a;
    --zinc-600: #52525b;
    --zinc-800: #27272a;
    --ink: #1d1d1f;
    --nav-h: 72px;
    --content-max-w: 680px;
  }

  /* ─── NAV ─── */
  #navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 3rem;
    height: var(--nav-h);
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--ink);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.975rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: inherit;
    text-decoration: none;
  }

  .logo-img {
    height: 32px;
    width: auto;
    display: block;
  }

  .back-link {
    font-size: 0.875rem;
    color: inherit;
    opacity: 0.65;
    transition: opacity 0.2s;
  }
  .back-link:hover { opacity: 1; }

  /* ─── HERO ─── */
  .hero {
    background: var(--white);
    padding: calc(var(--nav-h) + 8rem) 3rem 8rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--ink);
  }

  /* ─── EYEBROW ─── */
  .eyebrow {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--zinc-500);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  /* ─── BODY TEXT ─── */
  .body-text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--zinc-600);
  }

  /* ─── SECTION WRAP ─── */
  .section-wrap {
    max-width: var(--content-max-w);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ─── WHAT WE DO ─── */
  .what-section {
    background: var(--zinc-100);
    padding: 8rem 3rem;
  }

  .what-section h2 {
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  /* ─── TEAM ─── */
  .team-section {
    background: var(--white);
    padding: 8rem 3rem;
  }

  .team-header {
    max-width: var(--content-max-w);
    margin: 0 auto 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .team-header h2 {
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .person-grid {
    max-width: var(--content-max-w);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .person-card {
    border: 1px solid #e4e4e7;
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .person-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .person-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .person-role {
    font-size: 0.8rem;
    color: var(--zinc-500);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .person-bio {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--zinc-600);
  }

  .person-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink);
    align-self: flex-start;
    transition: opacity 0.2s;
  }
  .person-link:hover { opacity: 0.6; }

  /* ─── CONTACT ─── */
  .contact-section {
    background: var(--zinc-100);
    padding: 8rem 3rem;
  }

  .contact-section h2 {
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .contact-link {
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    align-self: flex-start;
    transition: opacity 0.2s;
  }
  .contact-link:hover { opacity: 0.6; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 640px) {
    #navbar { padding: 0 1.5rem; }
    .hero { padding: calc(var(--nav-h) + 5rem) 1.5rem 5rem; }
    .what-section, .team-section, .contact-section { padding: 5rem 1.5rem; }
  }
</style>
