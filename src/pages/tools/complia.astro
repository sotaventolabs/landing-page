---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="compl.ia · ISAE 3000 · Sotavento Labs"
  description="compl.ia builds the continuous, verifiable control record that ISAE 3000 Type II requires. When your auditor arrives, the evidence is already there."
>
  <!-- Skip to content for keyboard/screen-reader users -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- NAVIGATION -->
  <nav id="navbar" aria-label="Main navigation">
    <a href="/" class="logo" aria-label="Sotavento Labs — home">
      <img src="/logo.svg" alt="Sotavento Labs logo" class="logo-img" />
      Sotavento Labs
    </a>
    <div class="nav-right">
      <span class="nav-product">compl.ia</span>
      <a href="/#tools" class="back-link">← All tools</a>
    </div>
  </nav>

  <main id="main-content">
    <!-- HERO — Soft Grey -->
    <section id="hero" class="hero">
      <div class="section-wrap">
        <span class="eyebrow">ANALYSIS GAP FOR ISAE 3000</span>
        <h1>Your Audit Window Is Fixed.<br />Your Evidence Gap Isn't.</h1>
        <p class="body-text">
          Sotavento Labs builds the continuous, verifiable control record that
          ISAE 3000 Type II requires. When your auditor arrives, the evidence
          is already there.
        </p>
      </div>
    </section>

    <!-- PROBLEM — Gray -->
    <section id="problem" class="problem">
      <div class="section-wrap">
        <span class="eyebrow">THE CONSULTING MODEL PROBLEM</span>
        <h2>Traditional Consulting Was Built for a Different Era of Compliance.</h2>
        <p class="body-text">
          ISAE 3000 Type II requires 12 months of continuous, verifiable control operation.
          A 10-week consulting engagement cannot produce that. It can only describe it.
          Auditors know the difference.
        </p>
      </div>
    </section>

    <!-- SOLUTION — Black -->
    <section id="solution" class="solution">
      <div class="section-wrap solution-intro">
        <span class="eyebrow">HOW SOTAVENTO LABS WORKS</span>
        <h2>Built for the Way ISAE 3000 Is Actually Audited.</h2>
        <p class="body-text muted">
          Three integrated capabilities that replace the consulting cycle with a
          continuous, auditor-ready control record.
        </p>
      </div>
      <div class="pillars">
        <article class="pillar">
          <span class="pillar-icon" aria-hidden="true">
            <i data-lucide="activity"></i>
          </span>
          <h3>Continuous Evidence Capture</h3>
          <p class="pillar-body">
            Controls are documented at the moment they operate, not reconstructed
            weeks before your audit window. System logs, access records, policy
            acknowledgements, and operational artifacts are captured, timestamped,
            and mapped automatically.
          </p>
          <p class="replaces">
            What this replaces: Retrospective evidence assembly under deadline pressure.
          </p>
        </article>

        <article class="pillar">
          <span class="pillar-icon" aria-hidden="true">
            <i data-lucide="git-merge"></i>
          </span>
          <h3>Criteria Mapping</h3>
          <p class="pillar-body">
            Every control is mapped to the ISAE 3000 framework and COSO domains: Control
            Environment, Risk Assessment, Control Activities, Information &amp; Communication,
            Monitoring. Gaps are surfaced before your auditor finds them.
          </p>
          <p class="replaces">
            What this replaces: Manual gap analysis and consultant interpretation layers.
          </p>
        </article>

        <article class="pillar">
          <span class="pillar-icon" aria-hidden="true">
            <i data-lucide="layout-dashboard"></i>
          </span>
          <h3>Practitioner Portal</h3>
          <p class="pillar-body">
            Your ISAE 3000 practitioner accesses a structured, evidence-linked readiness
            view: no briefing cycles, no file transfers, no interpretation gaps. The
            evidence speaks directly to the criteria.
          </p>
          <p class="replaces">
            What this replaces: The consultant-as-translator layer between your technical
            environment and the auditor.
          </p>
        </article>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script is:inline>
    lucide.createIcons();

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.registerPlugin(ScrollTrigger);

      document.querySelectorAll('.hero, .section-wrap, .pillar').forEach((el) => {
        gsap.from(el, {
          opacity: 0,
          y: 30,
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        });
      });
    }

    const navbar = document.getElementById('navbar');
    const solutionEl = document.getElementById('solution');

    if (solutionEl) {
      new IntersectionObserver(
        ([e]) => navbar.classList.toggle('nav-dark', e.isIntersecting),
        { threshold: 0.1 }
      ).observe(solutionEl);
    }
  </script>
</Layout>

<style>
  /* ─── SKIP LINK ─── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-4);
    z-index: 200;
    padding: var(--space-2) var(--space-4);
    background: var(--ink);
    color: var(--fg-inverse);
    font-size: var(--fs-caption);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    transition: top var(--dur-fast);
  }
  .skip-link:focus { top: 0; }

  /* ─── NAV ─── */
  #navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--page-pad-x);
    height: var(--nav-h);
    background: var(--glass-bg-light);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    color: var(--fg-1);
    transition: background var(--dur-slow) ease, color var(--dur-slow) ease;
  }

  #navbar.nav-dark {
    background: var(--glass-bg-dark);
    color: var(--fg-inverse);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.975rem;
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-snug);
    color: inherit;
    text-decoration: none;
  }

  .logo-img {
    height: 32px;
    width: auto;
    display: block;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }

  .nav-product {
    font-size: var(--fs-caption);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tightish);
    color: inherit;
  }

  .back-link {
    font-size: var(--fs-caption);
    color: inherit;
    opacity: 0.65;
    transition: opacity 0.2s;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .back-link:hover { opacity: 1; }

  /* ─── HERO ─── */
  .hero {
    background: var(--surface-2);
    padding: calc(var(--nav-h) + var(--space-10)) var(--page-pad-x) var(--space-10);
  }

  .hero h1 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
    line-height: 1.15;
    color: var(--fg-1);
  }

  /* ─── EYEBROW ─── */
  .eyebrow {
    display: inline-block;
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-eyebrow);
    color: var(--fg-3);
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  /* ─── BODY TEXT ─── */
  .body-text {
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--fg-2);
  }
  /* #a1a1aa on black = 8.5:1 — passes WCAG AA */
  .body-text.muted { color: var(--fg-4); }

  /* ─── SECTION WRAP ─── */
  .section-wrap {
    max-width: var(--content-max-w);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ─── PROBLEM ─── */
  .problem {
    background: var(--surface-ash);
    padding: var(--space-10) var(--page-pad-x);
    color: var(--fg-inverse);
  }

  /* #a1a1aa on #3f3f46 = 4.35:1 — passes for large text (18px+/14px bold+); eyebrow is small so use white */
  .problem .eyebrow { color: var(--fg-inverse); opacity: 0.6; }

  .problem h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.1rem);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--lh-title);
    color: var(--fg-inverse);
  }

  .problem .body-text { color: var(--fg-4); }

  /* ─── SOLUTION ─── */
  .solution {
    background: var(--surface-ink);
    padding: var(--space-10) var(--page-pad-x);
    color: var(--fg-inverse);
  }

  .solution-intro { margin-bottom: var(--space-8); }

  /* #a1a1aa on black = 8.5:1 — passes */
  .solution .eyebrow { color: var(--fg-4); }

  .solution h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.1rem);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--lh-title);
    color: var(--fg-inverse);
  }

  /* ─── PILLARS ─── */
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    max-width: var(--wide-max-w);
    margin: 0 auto;
  }

  .pillar {
    background: rgba(24, 24, 27, 0.5);
    border: 1px solid var(--border-dark);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: background var(--dur) ease, transform var(--dur) ease;
  }

  .pillar:hover {
    background: rgba(39, 39, 42, 0.8);
    transform: translateY(-2px);
  }

  .pillar-icon {
    color: var(--fg-inverse);
    display: flex;
    align-items: center;
    width: 22px;
    height: 22px;
  }

  .pillar-icon svg { width: 22px; height: 22px; }

  .pillar h3 {
    font-size: 0.975rem;
    font-weight: var(--fw-semibold);
    color: var(--fg-inverse);
    letter-spacing: var(--tracking-tightish);
  }

  .pillar-body {
    font-size: var(--fs-caption);
    line-height: 1.75;
    /* #a1a1aa on black pillar bg ≈ 8.5:1 — passes WCAG AA */
    color: var(--fg-4);
    flex: 1;
  }

  /* Was #52525b on black = 2.66:1 (fail). Now #808080 on black = 5.3:1 (pass) */
  .replaces {
    font-size: var(--fs-micro);
    line-height: var(--lh-tight);
    color: #808080;
    border-top: 1px solid var(--border-dark);
    padding-top: 0.875rem;
    margin-top: auto;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 960px) {
    .pillars {
      grid-template-columns: 1fr;
      max-width: 600px;
    }
  }

  @media (max-width: 640px) {
    #navbar { padding: 0 var(--page-pad-x-sm); }
    .hero { padding: calc(var(--nav-h) + 5rem) var(--page-pad-x-sm) 5rem; }
    .problem, .solution { padding: 5rem var(--page-pad-x-sm); }
  }
</style>
