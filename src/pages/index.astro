---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <!-- NAVIGATION -->
  <nav id="navbar">
    <a href="/" class="logo">
      <img src="/logo.png" alt="" class="logo-img" />
      Sotavento Labs
    </a>
    <a href="/about" class="nav-link">About</a>
    <a href="#tools" class="nav-link">What we're building</a>
  </nav>

  <main>
    <!-- HERO — White -->
    <section id="hero" class="hero-a">
      <div class="section-wrap">
        <h1>Technology consulting<br />for teams that build.</h1>
        <p class="body-text">
          We help engineering teams ship better software — from architecture and
          infrastructure to hands-on delivery.
        </p>
      </div>
    </section>

    <!-- TOOLS & PROJECTS -->
    <section id="tools" class="tools-section">
      <div class="tools-header">
        <span class="eyebrow">WHAT WE'RE BUILDING</span>
        <h2>Tools &amp; Projects</h2>
        <p class="tools-sub">Focused products built on top of our consulting practice.</p>
      </div>

      <div class="carousel-wrapper">
        <div class="carousel" id="carousel">
          <a href="/tools/complia" class="tool-card">
            <span class="card-tag">compl.ia</span>
            <h3>Your Audit Window Is Fixed.<br />Your Evidence Gap Isn't.</h3>
            <p class="card-body">
              Continuous, verifiable control records that ISAE 3000 Type II
              requires — ready when your auditor arrives.
            </p>
            <span class="card-cta">Explore →</span>
          </a>
        </div>

        <div class="carousel-nav" id="carousel-nav" aria-hidden="true">
          <button class="carousel-btn" id="prev" aria-label="Previous">‹</button>
          <div class="carousel-dots" id="dots"></div>
          <button class="carousel-btn" id="next" aria-label="Next">›</button>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script is:inline>
    lucide.createIcons();

    gsap.registerPlugin(ScrollTrigger);

    document.querySelectorAll('.hero-a, .tools-section, .tool-card').forEach((el) => {
      gsap.from(el, {
        opacity: 0,
        y: 30,
        duration: 0.8,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          toggleActions: 'play none none none',
        },
      });
    });

    // Carousel
    const carousel = document.getElementById('carousel');
    const dotsContainer = document.getElementById('dots');
    const prevBtn = document.getElementById('prev');
    const nextBtn = document.getElementById('next');
    const cards = carousel ? Array.from(carousel.querySelectorAll('.tool-card')) : [];

    if (cards.length > 1) {
      document.getElementById('carousel-nav').removeAttribute('aria-hidden');

      cards.forEach((_, i) => {
        const dot = document.createElement('button');
        dot.className = 'dot' + (i === 0 ? ' active' : '');
        dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        dot.addEventListener('click', () => scrollTo(i));
        dotsContainer.appendChild(dot);
      });

      function getActive() {
        const scrollLeft = carousel.scrollLeft;
        const cardWidth = cards[0].offsetWidth + 24; // gap
        return Math.round(scrollLeft / cardWidth);
      }

      function scrollTo(index) {
        const cardWidth = cards[0].offsetWidth + 24;
        carousel.scrollTo({ left: index * cardWidth, behavior: 'smooth' });
      }

      function updateDots() {
        const active = getActive();
        dotsContainer.querySelectorAll('.dot').forEach((d, i) =>
          d.classList.toggle('active', i === active)
        );
      }

      prevBtn.addEventListener('click', () => scrollTo(Math.max(0, getActive() - 1)));
      nextBtn.addEventListener('click', () => scrollTo(Math.min(cards.length - 1, getActive() + 1)));
      carousel.addEventListener('scroll', updateDots, { passive: true });
    }
  </script>
</Layout>

<style>
  :root {
    --white: #ffffff;
    --zinc-100: #f4f4f5;
    --zinc-400: #a1a1aa;
    --zinc-500: #71717a;
    --zinc-600: #52525b;
    --zinc-800: #27272a;
    --ink: #1d1d1f;
    --nav-h: 72px;
    --content-max-w: 680px;
  }

  /* ─── NAV ─── */
  #navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 3rem;
    height: var(--nav-h);
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    color: var(--ink);
  }

  .nav-link {
    font-size: 0.9rem;
    color: inherit;
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .nav-link:hover { opacity: 1; }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.975rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: inherit;
    text-decoration: none;
  }

  .logo-img {
    height: 32px;
    width: auto;
    display: block;
  }

  /* ─── HERO ─── */
  .hero-a {
    background: var(--white);
    padding: calc(var(--nav-h) + 8rem) 3rem 8rem;
  }

  .hero-a h1 {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }

  /* ─── EYEBROW ─── */
  .eyebrow {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--zinc-500);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  /* ─── BODY TEXT ─── */
  .body-text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--zinc-600);
  }

  .section-wrap {
    max-width: var(--content-max-w);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ─── TOOLS SECTION ─── */
  .tools-section {
    background: var(--zinc-100);
    padding: 8rem 3rem;
  }

  .tools-header {
    max-width: var(--content-max-w);
    margin: 0 auto 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tools-header h2 {
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .tools-sub {
    font-size: 1rem;
    color: var(--zinc-500);
    margin-top: 0.25rem;
  }

  /* ─── CAROUSEL ─── */
  .carousel-wrapper {
    max-width: 1100px;
    margin: 0 auto;
  }

  .carousel {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
  }

  .carousel::-webkit-scrollbar { display: none; }

  /* ─── TOOL CARD ─── */
  .tool-card {
    flex: 0 0 340px;
    scroll-snap-align: start;
    background: var(--white);
    border: 1px solid #e4e4e7;
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
    text-decoration: none;
    color: inherit;
  }

  .tool-card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .card-tag {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--zinc-500);
    background: var(--zinc-100);
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
    align-self: flex-start;
  }

  .tool-card h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--ink);
  }

  .card-body {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--zinc-600);
    flex: 1;
  }

  .card-cta {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink);
    margin-top: auto;
  }

  /* ─── CAROUSEL NAV ─── */
  .carousel-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .carousel-nav[aria-hidden="true"] { display: none; }

  .carousel-btn {
    background: none;
    border: 1.5px solid #d4d4d8;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    color: var(--zinc-600);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s;
  }

  .carousel-btn:hover { border-color: var(--ink); color: var(--ink); }

  .carousel-dots { display: flex; gap: 0.5rem; }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #d4d4d8;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }

  .dot.active { background: var(--ink); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 640px) {
    #navbar { padding: 0 1.5rem; }
    .hero-a { padding: calc(var(--nav-h) + 5rem) 1.5rem 5rem; }
    .tools-section { padding: 5rem 1.5rem; }
    .tool-card { flex: 0 0 280px; }
  }
</style>
