---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- NAVIGATION -->
  <nav id="navbar">
    <a href="/" class="logo">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" aria-hidden="true">
        <polygon points="12 2 22 7 22 17 12 22 2 17 2 7" />
      </svg>
      Sotavento Labs
    </a>
    <div class="nav-right">
      <a href="/about.html" class="nav-link">About Us</a>
      <button class="open-modal nav-cta">Contact</button>
    </div>
  </nav>

  <main>
    <!-- 1. HERO — White -->
    <section id="hero" class="hero">
      <div class="hero-grid">
        <div class="hero-block hero-a">
          <h1>Technology consulting<br />for teams that build.</h1>
          <p class="body-text">
            We help engineering teams ship better software — from architecture and
            infrastructure to hands-on delivery.
          </p>
          <button class="open-modal btn-primary">Get in touch →</button>
        </div>
        <div class="hero-sep" aria-hidden="true"></div>
        <div class="hero-block hero-b">
          <span class="eyebrow">ANALYSIS GAP FOR ISAE 3000</span>
          <h2>Your Audit Window Is Fixed.<br />Your Evidence Gap Isn't.</h2>
          <p class="body-text justified">
            Sotavento Labs builds the continuous, verifiable control record that
            ISAE 3000 Type II requires — so when your auditor arrives, the evidence
            is already there.
          </p>
        </div>
      </div>
    </section>

    <!-- 2. PROBLEM — Gray -->
    <section id="problem" class="problem">
      <div class="section-wrap">
        <span class="eyebrow">THE CONSULTING MODEL PROBLEM</span>
        <h2>Traditional Consulting Was Built for a Different Era of Compliance.</h2>
        <p class="body-text justified">
          ISAE 3000 Type II requires 12 months of continuous, verifiable control operation.
          A 10-week consulting engagement cannot produce that — it can only describe it.
          Auditors know the difference.
        </p>
      </div>
    </section>

    <!-- 3. SOLUTION — Black -->
    <section id="solution" class="solution">
      <div class="section-wrap solution-intro">
        <span class="eyebrow dim">HOW SOTAVENTO LABS WORKS</span>
        <h2>Built for the Way ISAE 3000 Is Actually Audited.</h2>
        <p class="body-text muted justified">
          Three integrated capabilities that replace the consulting cycle with a
          continuous, auditor-ready control record.
        </p>
      </div>
      <div class="pillars">
        <article class="pillar">
          <span class="pillar-icon" aria-hidden="true">
            <i data-lucide="activity"></i>
          </span>
          <h3>Continuous Evidence Capture</h3>
          <p class="pillar-body">
            Controls are documented at the moment they operate — not reconstructed
            weeks before your audit window. System logs, access records, policy
            acknowledgements, and operational artifacts are captured, timestamped,
            and mapped automatically.
          </p>
          <p class="replaces">
            What this replaces: Retrospective evidence assembly under deadline pressure.
          </p>
        </article>

        <article class="pillar">
          <span class="pillar-icon" aria-hidden="true">
            <i data-lucide="git-merge"></i>
          </span>
          <h3>Criteria Mapping</h3>
          <p class="pillar-body">
            Every control is mapped to the ISAE 3000 framework and COSO domains — Control
            Environment, Risk Assessment, Control Activities, Information &amp; Communication,
            Monitoring. Gaps are surfaced before your auditor finds them.
          </p>
          <p class="replaces">
            What this replaces: Manual gap analysis and consultant interpretation layers.
          </p>
        </article>

        <article class="pillar">
          <span class="pillar-icon" aria-hidden="true">
            <i data-lucide="layout-dashboard"></i>
          </span>
          <h3>Practitioner Portal</h3>
          <p class="pillar-body">
            Your ISAE 3000 practitioner accesses a structured, evidence-linked readiness
            view — no briefing cycles, no file transfers, no interpretation gaps. The
            evidence speaks directly to the criteria.
          </p>
          <p class="replaces">
            What this replaces: The consultant-as-translator layer between your technical
            environment and the auditor.
          </p>
        </article>
      </div>
    </section>
  </main>

  <!-- CONTACT MODAL -->
  <div id="modal" class="modal-overlay" aria-hidden="true">
    <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <button id="close-modal" class="modal-close" aria-label="Close">
        <i data-lucide="x"></i>
      </button>
      <h3 id="modal-title" class="modal-title">Get in touch</h3>
      <form id="contact-form" novalidate>
        <div class="field">
          <input
            type="text"
            name="company"
            placeholder="Acme Corp"
            required
            autocomplete="organization"
          />
        </div>
        <div class="field">
          <input
            type="email"
            name="email"
            placeholder="hello@acmecorp.com"
            required
            autocomplete="email"
          />
        </div>
        <div class="field">
          <textarea
            name="message"
            rows="4"
            placeholder="How can we help you?"
          ></textarea>
        </div>
        <button type="submit" id="submit-btn" class="submit-btn">Send Message</button>
      </form>
    </div>
  </div>

  <!-- LINKEDIN FLOATING BUTTON -->
  <a
    href="https://linkedin.com/company/sotavento-labs/"
    target="_blank"
    rel="noopener noreferrer"
    class="linkedin-fab"
    aria-label="Sotavento Labs on LinkedIn"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>
  </a>

  <footer>
    <div class="footer-inner">
      <span>&copy; {new Date().getFullYear()} Sotavento Labs</span>
      <a href="mailto:hello@sotaventolabs.com">hello@sotaventolabs.com</a>
    </div>
  </footer>

  <!-- SCRIPTS — end of body guarantees DOM ready + correct load order -->
  <script is:inline src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script is:inline>
    lucide.createIcons();

    gsap.registerPlugin(ScrollTrigger);

    document.querySelectorAll('.hero-block, .section-wrap, .pillar').forEach((el) => {
      gsap.from(el, {
        opacity: 0,
        y: 30,
        duration: 0.8,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          toggleActions: 'play none none none',
        },
      });
    });

    // Nav colour switch when Solution section enters viewport
    const navbar = document.getElementById('navbar');
    const solutionEl = document.getElementById('solution');

    if (solutionEl) {
      new IntersectionObserver(
        ([e]) => navbar.classList.toggle('nav-dark', e.isIntersecting),
        { threshold: 0.1 }
      ).observe(solutionEl);
    }

    // Modal
    const modal = document.getElementById('modal');
    const closeBtn = document.getElementById('close-modal');
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');

    const openModal = () => {
      modal.removeAttribute('aria-hidden');
      modal.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    };

    const closeModal = () => {
      modal.setAttribute('aria-hidden', 'true');
      modal.classList.remove('is-open');
      document.body.style.overflow = '';
    };

    document.querySelectorAll('.open-modal').forEach((b) =>
      b.addEventListener('click', openModal)
    );
    closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const subject = encodeURIComponent('Inquiry from ' + form.company.value);
      const body = encodeURIComponent('From: ' + form.email.value + '\n\n' + form.message.value);
      window.open('mailto:hello@sotaventolabs.com?subject=' + subject + '&body=' + body, '_blank');

      submitBtn.textContent = 'Sent!';
      submitBtn.classList.add('is-sent');
      setTimeout(() => {
        closeModal();
        form.reset();
        submitBtn.textContent = 'Send Message';
        submitBtn.classList.remove('is-sent');
      }, 1500);
    });
  </script>
</Layout>

<style>
  /* ─── TOKENS ─── */
  :root {
    --white: #ffffff;
    --zinc-100: #f4f4f5;
    --zinc-400: #a1a1aa;
    --zinc-500: #71717a;
    --zinc-600: #52525b;
    --zinc-800: #27272a;
    --zinc-900: #18181b;
    --black: #000000;
    --ink: #1d1d1f;
    --nav-h: 72px;
  }

  /* ─── NAV ─── */
  #navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 3rem;
    height: var(--nav-h);
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--ink);
    transition: background 0.4s ease, color 0.4s ease;
  }

  #navbar.nav-dark {
    background: rgba(0, 0, 0, 0.8);
    color: var(--white);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.975rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: inherit;
    text-decoration: none;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.9rem;
    color: inherit;
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.2s;
  }
  .nav-link:hover { opacity: 1; }

  .nav-cta {
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 6px;
    cursor: pointer;
    border: 1.5px solid currentColor;
    background: transparent;
    color: inherit;
    font-family: inherit;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  #navbar:not(.nav-dark) .nav-cta:hover {
    background: var(--ink);
    color: var(--white);
    border-color: var(--ink);
  }

  #navbar.nav-dark .nav-cta:hover {
    background: var(--white);
    color: var(--ink);
    border-color: var(--white);
  }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    background: var(--white);
    padding-top: var(--nav-h);
    display: flex;
    align-items: center;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    width: 100%;
    min-height: calc(100vh - var(--nav-h));
    align-items: center;
  }

  .hero-sep {
    background: #e4e4e7;
    align-self: stretch;
    margin: 6rem 0;
  }

  .hero-block { padding: 4rem 3rem; }

  .hero-a h1 {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }

  .hero-b {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-b h2 {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--ink);
  }

  /* ─── EYEBROW ─── */
  .eyebrow {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--zinc-500);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .eyebrow.dim { color: var(--zinc-600); }

  /* ─── BODY TEXT ─── */
  .body-text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--zinc-600);
    max-width: 48ch;
  }
  .body-text.muted { color: var(--zinc-400); }
  .body-text.justified { text-align: justify; }

  /* ─── BUTTON ─── */
  .btn-primary {
    display: inline-block;
    margin-top: 2rem;
    padding: 0.75rem 1.75rem;
    font-size: 0.975rem;
    font-weight: 500;
    color: var(--white);
    background: var(--ink);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.85; }

  /* ─── PROBLEM ─── */
  .problem {
    background: var(--zinc-100);
    padding: 8rem 3rem;
  }

  .section-wrap {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .problem h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.1rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.2;
    color: var(--ink);
  }

  /* ─── SOLUTION ─── */
  .solution {
    background: var(--black);
    padding: 8rem 3rem;
    color: var(--white);
  }

  .solution-intro { margin-bottom: 4rem; }

  .solution h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.1rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.2;
    color: var(--white);
  }

  /* ─── PILLARS ─── */
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .pillar {
    background: rgba(24, 24, 27, 0.5);
    border: 1px solid var(--zinc-800);
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .pillar:hover {
    background: rgba(39, 39, 42, 0.8);
    transform: translateY(-2px);
  }

  .pillar-icon {
    color: var(--white);
    display: flex;
    align-items: center;
    width: 22px;
    height: 22px;
  }

  .pillar-icon svg {
    width: 22px;
    height: 22px;
  }

  .pillar h3 {
    font-size: 0.975rem;
    font-weight: 600;
    color: var(--white);
    letter-spacing: -0.01em;
  }

  .pillar-body {
    font-size: 0.875rem;
    line-height: 1.75;
    color: var(--zinc-400);
    text-align: justify;
    flex: 1;
  }

  .replaces {
    font-size: 0.775rem;
    line-height: 1.5;
    color: var(--zinc-600);
    border-top: 1px solid var(--zinc-800);
    padding-top: 0.875rem;
    margin-top: auto;
  }

  /* ─── MODAL ─── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .modal-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .modal-box {
    background: var(--white);
    border-radius: 16px;
    padding: 2.5rem;
    width: 100%;
    max-width: 460px;
    position: relative;
    transform: translateY(20px);
    transition: transform 0.3s ease;
  }

  .modal-overlay.is-open .modal-box {
    transform: translateY(0);
  }

  .modal-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--zinc-500);
    border-radius: 4px;
    padding: 0;
    transition: color 0.2s, background 0.2s;
  }

  .modal-close:hover {
    color: var(--ink);
    background: var(--zinc-100);
  }

  .modal-close svg { width: 16px; height: 16px; }

  .modal-title {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }

  #contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .field input,
  .field textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.925rem;
    font-family: inherit;
    border: 1.5px solid #e4e4e7;
    border-radius: 8px;
    background: var(--white);
    color: var(--ink);
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }

  .field input::placeholder,
  .field textarea::placeholder { color: var(--zinc-400); }

  .field input:focus,
  .field textarea:focus { border-color: var(--ink); }

  .submit-btn {
    padding: 0.75rem 1.5rem;
    font-size: 0.975rem;
    font-weight: 500;
    color: var(--white);
    background: var(--ink);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s, opacity 0.2s;
    margin-top: 0.25rem;
  }

  .submit-btn:hover { opacity: 0.85; }

  .submit-btn.is-sent {
    background: #16a34a;
    cursor: default;
    opacity: 1;
  }

  /* ─── LINKEDIN FAB ─── */
  .linkedin-fab {
    position: fixed;
    bottom: 1.75rem;
    right: 1.75rem;
    z-index: 150;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ink);
    color: var(--white);
    border-radius: 10px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.15);
    transition: opacity 0.2s, transform 0.2s;
  }

  .linkedin-fab:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }

  /* ─── FOOTER ─── */
  footer {
    border-top: 1px solid #e4e4e7;
    padding: 2rem 3rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.875rem;
    color: var(--zinc-500);
  }

  .footer-inner a {
    color: inherit;
    transition: color 0.2s;
  }
  .footer-inner a:hover { color: var(--ink); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-sep { display: none; }
    .hero-block { padding: 3rem 2rem; }
    .hero-a h1 { font-size: clamp(2rem, 5vw, 2.5rem); }
    .pillars {
      grid-template-columns: 1fr;
      max-width: 600px;
    }
  }

  @media (max-width: 640px) {
    #navbar { padding: 0 1.5rem; }
    .problem,
    .solution { padding: 5rem 1.5rem; }
    footer { padding: 1.5rem; }
    .footer-inner {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
