---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout description="Technology consulting for teams that build. We help engineering teams ship better software, from architecture and infrastructure to hands-on delivery.">
  <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Sotavento Labs",
      "url": "https://sotaventolabs.eu",
      "logo": "https://sotaventolabs.eu/logo.png",
      "email": "hello@sotaventolabs.eu",
      "sameAs": ["https://linkedin.com/company/sotavento-labs/"],
      "description": "Technology consulting for teams that build. We help engineering teams ship better software, from architecture and infrastructure to hands-on delivery."
    }
  </script>
  <!-- Skip to content for keyboard/screen-reader users -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- NAVIGATION -->
  <nav id="navbar" aria-label="Main navigation">
    <a href="/" class="logo" aria-label="Sotavento Labs — home">
      <img src="/logo.svg" alt="Sotavento Labs logo" class="logo-img" />
      Sotavento Labs
    </a>

    <ul class="nav-links" id="nav-links" role="list">
      <li><a href="/about" class="nav-link">About</a></li>
      <li><a href="#tools" class="nav-link">What we're building</a></li>
    </ul>

    <button
      class="nav-toggle"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="nav-links"
      aria-label="Open navigation menu"
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </nav>

  <main id="main-content">
    <!-- HERO — White -->
    <section id="hero" class="hero-a">
      <div class="section-wrap">
        <h1>Technology consulting<br />for teams that build.</h1>
        <p class="body-text">
          We help engineering teams ship better software, from architecture and
          infrastructure to hands-on delivery.
        </p>
      </div>
    </section>

    <!-- TOOLS & PROJECTS -->
    <section id="tools" class="tools-section">
      <div class="tools-header">
        <span class="eyebrow">WHAT WE'RE BUILDING</span>
        <h2>Tools &amp; Projects</h2>
        <p class="tools-sub">Focused products built on top of our consulting practice.</p>
      </div>

      <div class="carousel-wrapper">
        <div class="carousel" id="carousel">
          <a href="/tools/complia" class="tool-card">
            <span class="card-tag">compl.ia</span>
            <h3>Your Audit Window Is Fixed.<br />Your Evidence Gap Isn't.</h3>
            <p class="card-body">
              Continuous, verifiable control records that ISAE 3000 Type II
              requires, ready when your auditor arrives.
            </p>
            <span class="card-cta">Explore →</span>
          </a>
        </div>

        <div class="carousel-nav" id="carousel-nav" aria-hidden="true">
          <button class="carousel-btn" id="prev" aria-label="Previous">‹</button>
          <div class="carousel-dots" id="dots"></div>
          <button class="carousel-btn" id="next" aria-label="Next">›</button>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script is:inline>
    // Mobile nav toggle
    const toggle = document.getElementById('nav-toggle');
    const navLinks = document.getElementById('nav-links');
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      toggle.setAttribute('aria-label', isOpen ? 'Open navigation menu' : 'Close navigation menu');
      navLinks.classList.toggle('open', !isOpen);
    });
    // Close menu on link click (single-page scroll links)
    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Open navigation menu');
        navLinks.classList.remove('open');
      });
    });

    lucide.createIcons();

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.registerPlugin(ScrollTrigger);

      document.querySelectorAll('.hero-a, .tools-section, .tool-card').forEach((el) => {
        gsap.from(el, {
          opacity: 0,
          y: 30,
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        });
      });
    }

    // Carousel
    const carousel = document.getElementById('carousel');
    const dotsContainer = document.getElementById('dots');
    const prevBtn = document.getElementById('prev');
    const nextBtn = document.getElementById('next');
    const cards = carousel ? Array.from(carousel.querySelectorAll('.tool-card')) : [];

    if (cards.length > 1) {
      document.getElementById('carousel-nav').removeAttribute('aria-hidden');

      cards.forEach((_, i) => {
        const dot = document.createElement('button');
        dot.className = 'dot' + (i === 0 ? ' active' : '');
        dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        dot.addEventListener('click', () => scrollTo(i));
        dotsContainer.appendChild(dot);
      });

      function getActive() {
        const scrollLeft = carousel.scrollLeft;
        const cardWidth = cards[0].offsetWidth + 24; // gap
        return Math.round(scrollLeft / cardWidth);
      }

      function scrollTo(index) {
        const cardWidth = cards[0].offsetWidth + 24;
        carousel.scrollTo({ left: index * cardWidth, behavior: 'smooth' });
      }

      function updateDots() {
        const active = getActive();
        dotsContainer.querySelectorAll('.dot').forEach((d, i) =>
          d.classList.toggle('active', i === active)
        );
      }

      prevBtn.addEventListener('click', () => scrollTo(Math.max(0, getActive() - 1)));
      nextBtn.addEventListener('click', () => scrollTo(Math.min(cards.length - 1, getActive() + 1)));
      carousel.addEventListener('scroll', updateDots, { passive: true });
    }
  </script>
</Layout>

<style>
  /* ─── SKIP LINK ─── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-4);
    z-index: 200;
    padding: var(--space-2) var(--space-4);
    background: var(--ink);
    color: var(--fg-inverse);
    font-size: var(--fs-caption);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    transition: top var(--dur-fast);
  }
  .skip-link:focus { top: 0; }

  /* ─── NAV ─── */
  #navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--page-pad-x);
    height: var(--nav-h);
    background: var(--glass-bg-light);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: var(--hairline-light);
    color: var(--fg-1);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.975rem;
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-snug);
    color: inherit;
    text-decoration: none;
  }

  .logo-img {
    height: 32px;
    width: auto;
    display: block;
  }

  /* Nav links — grouped on the right, close together */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-size: var(--fs-caption);
    color: inherit;
    text-decoration: none;
    opacity: 0.7;
    transition: opacity var(--dur);
    /* Ensure tap target height matches nav */
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .nav-link:hover,
  .nav-link:focus-visible { opacity: 1; }
  .nav-link[aria-current="page"] { opacity: 1; font-weight: var(--fw-semibold); }

  /* Hamburger — hidden on desktop */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    border-radius: var(--radius-md);
  }
  .bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    border-radius: var(--radius-xs);
    transition: transform var(--dur) ease, opacity var(--dur) ease;
  }
  /* Animate hamburger → X */
  .nav-toggle[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ─── HERO ─── */
  .hero-a {
    background: var(--surface);
    padding: calc(var(--nav-h) + var(--space-10)) var(--page-pad-x) var(--space-10);
  }

  .hero-a h1 {
    font-size: clamp(var(--fs-h1-min), 3.5vw, var(--fs-h1-max));
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--lh-display);
    color: var(--fg-1);
    margin-bottom: var(--space-5);
  }

  /* ─── EYEBROW ─── */
  .eyebrow {
    display: inline-block;
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-eyebrow);
    color: var(--fg-3);
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  /* ─── BODY TEXT ─── */
  .body-text {
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--fg-2);
  }

  .section-wrap {
    max-width: var(--content-max-w);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ─── TOOLS SECTION ─── */
  .tools-section {
    background: var(--surface-2);
    padding: var(--space-10) var(--page-pad-x);
  }

  .tools-header {
    max-width: var(--content-max-w);
    margin: 0 auto var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .tools-header h2 {
    font-size: clamp(var(--fs-h2-min), 2.5vw, var(--fs-h2-max));
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
    color: var(--fg-1);
  }

  .tools-sub {
    font-size: var(--fs-body);
    color: var(--fg-3);
    margin-top: var(--space-1);
  }

  /* ─── CAROUSEL ─── */
  .carousel-wrapper {
    max-width: var(--wide-max-w);
    margin: 0 auto;
  }

  .carousel {
    display: flex;
    gap: var(--space-5);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: var(--space-2);
  }

  .carousel::-webkit-scrollbar { display: none; }

  /* ─── TOOL CARD ─── */
  .tool-card {
    flex: 0 0 340px;
    scroll-snap-align: start;
    background: var(--surface);
    border: 1px solid var(--border-1);
    border-radius: var(--radius-2xl);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: box-shadow var(--dur) ease, transform var(--dur) ease;
    text-decoration: none;
    color: inherit;
  }

  .tool-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .card-tag {
    font-size: 0.65rem;
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tag);
    text-transform: uppercase;
    color: var(--fg-3);
    background: var(--surface-2);
    padding: 0.3rem 0.6rem;
    border-radius: var(--radius-sm);
    align-self: flex-start;
  }

  .tool-card h3 {
    font-size: var(--fs-card-title);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-snug);
    line-height: var(--lh-cramped);
    color: var(--fg-1);
  }

  .card-body {
    font-size: var(--fs-caption);
    line-height: var(--lh-body);
    color: var(--fg-2);
    flex: 1;
  }

  .card-cta {
    font-size: var(--fs-caption);
    font-weight: var(--fw-medium);
    color: var(--fg-1);
    margin-top: auto;
  }

  /* ─── CAROUSEL NAV ─── */
  .carousel-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-5);
  }

  .carousel-nav[aria-hidden="true"] { display: none; }

  .carousel-btn {
    background: none;
    border: 1.5px solid var(--border-2);
    border-radius: 50%;
    width: 32px;
    height: 32px;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    color: var(--fg-2);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color var(--dur), color var(--dur);
  }

  .carousel-btn:hover { border-color: var(--fg-1); color: var(--fg-1); }

  .carousel-dots { display: flex; gap: var(--space-2); }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border-2);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background var(--dur);
  }

  .dot.active { background: var(--fg-1); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 640px) {
    #navbar { padding: 0 var(--page-pad-x-sm); }
    .hero-a { padding: calc(var(--nav-h) + 5rem) var(--page-pad-x-sm) 5rem; }
    .tools-section { padding: 5rem var(--page-pad-x-sm); }
    .tool-card { flex: 0 0 280px; }

    /* Show hamburger, hide inline links */
    .nav-toggle { display: flex; }

    .nav-links {
      position: fixed;
      top: var(--nav-h);
      left: 0; right: 0;
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border-bottom: var(--hairline-light);
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding: var(--space-2) var(--page-pad-x-sm) var(--space-4);
      /* Hidden by default */
      visibility: hidden;
      opacity: 0;
      transform: translateY(-8px);
      transition: opacity var(--dur) ease, transform var(--dur) ease, visibility 0s var(--dur);
    }
    .nav-links.open {
      visibility: visible;
      opacity: 1;
      transform: translateY(0);
      transition: opacity var(--dur) ease, transform var(--dur) ease;
    }
    .nav-links li { width: 100%; }
    .nav-link {
      width: 100%;
      padding: var(--space-3) 0;
      border-bottom: var(--hairline-light);
      min-height: 44px;
    }
    .nav-links li:last-child .nav-link { border-bottom: none; }
  }
</style>
