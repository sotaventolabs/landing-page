<button id="cookie-prefs-btn" aria-label="Cookie preferences">🍪</button>

<div
  id="cookie-banner"
  role="dialog"
  aria-label="Cookie consent"
  aria-modal="false"
  aria-live="polite"
  hidden
>
  <div class="cookie-inner">
    <p class="cookie-text">
      We use analytics to understand how visitors use this site. No data is
      collected without your consent.
    </p>
    <div class="cookie-actions">
      <button id="cookie-decline" class="btn-outline">Decline</button>
      <button id="cookie-accept" class="btn-solid">Accept</button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var CONSENT_KEY = 'sl_cookie_consent';

    function loadAnalytics() {
      // Telemetric
      var telemetric = document.createElement('script');
      telemetric.src =
        '//web.telemetric.dk/t/f12a7a97-9df3-4826-8f70-0b946fbe6881/bm.js';
      telemetric.async = true;
      document.head.appendChild(telemetric);

      // Vercel Analytics
      var va = document.createElement('script');
      va.src = '/_vercel/insights/script.js';
      va.defer = true;
      document.head.appendChild(va);
    }

    var banner = document.getElementById('cookie-banner');
    var consent = localStorage.getItem(CONSENT_KEY);

    if (consent === 'accepted') {
      // Defer until all page resources are done — analytics is non-critical
      window.addEventListener('load', loadAnalytics);
    } else if (consent === null) {
      banner.removeAttribute('hidden');
    }
    // 'declined' → banner stays hidden, nothing loads

    document.getElementById('cookie-accept').addEventListener('click', function () {
      localStorage.setItem(CONSENT_KEY, 'accepted');
      banner.setAttribute('hidden', '');
      loadAnalytics();
    });

    document.getElementById('cookie-decline').addEventListener('click', function () {
      localStorage.setItem(CONSENT_KEY, 'declined');
      banner.setAttribute('hidden', '');
    });

    document.getElementById('cookie-prefs-btn').addEventListener('click', function () {
      localStorage.removeItem(CONSENT_KEY);
      window.location.reload();
    });
  })();
</script>

<style>
  #cookie-banner {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 999;
    width: calc(100% - 3rem);
    max-width: 680px;
    background: #1d1d1f;
    color: #f4f4f5;
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .cookie-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .cookie-text {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #a1a1aa;
    flex: 1;
    min-width: 200px;
    margin: 0;
  }

  .cookie-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .btn-outline,
  .btn-solid {
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 1.1rem;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s, border-color 0.2s, color 0.2s;
    white-space: nowrap;
    font-family: inherit;
  }

  .btn-outline {
    background: transparent;
    border: 1.5px solid #52525b;
    color: #a1a1aa;
  }
  .btn-outline:hover {
    border-color: #a1a1aa;
    color: #f4f4f5;
  }

  .btn-solid {
    background: #f4f4f5;
    border: 1.5px solid #f4f4f5;
    color: #1d1d1f;
  }
  .btn-solid:hover {
    opacity: 0.88;
  }

  #cookie-prefs-btn {
    position: fixed;
    bottom: 1.5rem;
    left: 1.5rem;
    z-index: 998;
    background: #fff;
    border: 1.5px solid #e4e4e7;
    border-radius: 8px;
    padding: 0.4rem 0.6rem;
    font-size: 1.1rem;
    line-height: 1;
    color: #71717a;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: border-color 0.2s, color 0.2s;
  }
  #cookie-prefs-btn:hover {
    border-color: #a1a1aa;
    color: #1d1d1f;
  }
  #cookie-prefs-btn:focus-visible {
    outline: 2px solid #1d1d1f;
    outline-offset: 3px;
  }

  @media (max-width: 480px) {
    #cookie-banner {
      bottom: 1rem;
      width: calc(100% - 2rem);
    }
    .cookie-inner {
      flex-direction: column;
      gap: 1rem;
    }
    .cookie-actions {
      width: 100%;
      justify-content: flex-end;
    }
  }
</style>
