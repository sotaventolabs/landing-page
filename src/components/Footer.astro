---
---

<footer>
  <div class="footer-inner">
    <span>&copy; {new Date().getFullYear()} Sotavento Labs</span>
    <div class="footer-contacts">
      <a href="/privacy-policy">Privacy Policy</a>
      <a href="/terms">Terms of Service</a>
      <a href="mailto:hello@sotaventolabs.eu">hello@sotaventolabs.eu</a>
      <a
        href="https://linkedin.com/company/sotavento-labs/"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-linkedin"
        aria-label="Sotavento Labs on LinkedIn (opens in new tab)"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <span aria-hidden="true">Sotavento Labs</span>
      </a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border-1);
    padding: var(--space-6) var(--page-pad-x);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--fs-caption);
    color: var(--fg-3);
  }

  .footer-contacts {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }

  .footer-inner a {
    color: inherit;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .footer-inner a:hover { color: var(--fg-1); }

  .footer-linkedin {
    gap: 0.4rem;
  }

  @media (max-width: 640px) {
    footer { padding: var(--page-pad-x-sm); }
    .footer-inner { flex-direction: column; gap: var(--space-2); text-align: center; }
  }
</style>
