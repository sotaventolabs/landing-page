---
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Sotavento Labs',
	description = 'Technology consulting for teams that build. We help engineering teams ship better software, from architecture and infrastructure to hands-on delivery.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://sotaventolabs.eu');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<link rel="canonical" href={canonicalURL} />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body>
		<slot />
		<CookieBanner />
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display',
			'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	body {
		min-height: 100vh;
		color: #1d1d1f;
		background: #fbfbfd;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	/* Respect reduced motion — CSS transitions */
	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
		}
	}
</style>
